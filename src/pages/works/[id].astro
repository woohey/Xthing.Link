---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { findRelatedPostsForProject } from '../../lib/content-hub.js';
import {
  deployLabel,
  displayStack,
  displayTopicTags,
  projectActions,
  statusLabel,
} from '../../lib/project-display';
import { ROUTES } from '../../lib/routes';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  const posts = await getCollection('blog', ({ data }) => data.draft !== true);
  return projects.map((entry) => ({
    params: { id: entry.id },
    props: { entry, relatedPosts: findRelatedPostsForProject(entry, posts) },
  }));
}

const { entry, relatedPosts } = Astro.props;
const { Content } = await render(entry);
const {
  title, description, status, deployType,
  startedAt, updatedAt,
} = entry.data;
const projectStatus = statusLabel(status);
const projectDeployment = deployLabel(deployType);
const stack = displayStack(entry);
const topicTags = displayTopicTags(entry);
const actions = projectActions(entry).filter((action) => action.label !== '详情');
---

<BaseLayout title={title} description={description}>
  <article class="prose prose--wide article-page">
    <p class="muted" style="margin-bottom: 0.25rem;">
      <a href={ROUTES.works}>&larr; Works</a>
    </p>
    <header class="article-hero">
      <div class="article-hero__main">
        <p class="soft-pill">Works detail</p>
        <h1 class="page-title">{title}</h1>
        <p class="page-subtitle">{description}</p>
        <div class="project-taxonomy project-taxonomy--detail">
          <div class="project-taxonomy__group">
            <span class="project-taxonomy__label">状态</span>
            <div class="project-taxonomy__chips">
              {projectStatus && <span class="project-taxonomy__item">{projectStatus}</span>}
              {projectDeployment && <span class="project-taxonomy__item">{projectDeployment}</span>}
            </div>
          </div>
          {stack.length > 0 && (
            <div class="project-taxonomy__group">
              <span class="project-taxonomy__label">技术</span>
              <div class="project-taxonomy__chips">
                {stack.map((item: string) => <span class="project-taxonomy__item">{item}</span>)}
              </div>
            </div>
          )}
          {topicTags.length > 0 && (
            <div class="project-taxonomy__group">
              <span class="project-taxonomy__label">主题</span>
              <div class="project-taxonomy__chips">
                {topicTags.map((item: string) => <span class="project-taxonomy__item">{item}</span>)}
              </div>
            </div>
          )}
        </div>
      </div>
      <aside class="article-sidecard">
        <p class="article-sidecard__label">项目链接</p>
        <div class="article-sidecard__rows">
          {actions.map((action) => (
            <div class="article-sidecard__row">
              <span>{action.label}</span>
              <a href={action.href} target={action.external ? '_blank' : undefined} rel={action.external ? 'noopener' : undefined}>
                {action.external ? 'Open external' : 'Open'}
              </a>
            </div>
          ))}
          {startedAt && (
            <div class="article-sidecard__row">
              <span>开始</span>
              <strong>{new Date(startedAt).toLocaleDateString('en-CA')}</strong>
            </div>
          )}
          {updatedAt && (
            <div class="article-sidecard__row">
              <span>更新</span>
              <strong>{new Date(updatedAt).toLocaleDateString('en-CA')}</strong>
            </div>
          )}
        </div>
      </aside>
    </header>

    <div class="article-body">
      <Content />
    </div>

    {relatedPosts.length > 0 && (
      <section class="section">
        <h2>相关文章</h2>
        <div class="bento-grid">
          {relatedPosts.map((post: any) => (
            <a class="card card--clickable" href={`${ROUTES.blog}/${post.id}/`}>
              <div class="card__title">{post.data.title}</div>
              <p class="card__desc">{post.data.summary ?? post.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
