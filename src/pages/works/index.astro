---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { sortProjects } from '../../lib/content-hub.js';
import {
  deployLabel,
  displayStack,
  displayTopicTags,
  projectActions,
  projectDetailHref,
  statusLabel,
} from '../../lib/project-display';

const projects = sortProjects(await getCollection('projects'));
---

<BaseLayout title="Works" description="Projects, demos, and experiments on Xthing.Link.">
  <main class="prose prose--wide">
    <section class="page-intro page-intro--editorial">
      <p class="soft-pill">Works</p>
      <h1 class="page-title">项目实验室</h1>
      <p class="page-subtitle">
        这里汇集了所有项目与演示。每个条目对应一个独立的构建 —— 有的已在线部署，有的嵌入本站互动，有的还停留在代码仓库阶段。
      </p>
    </section>

    <div class="bento-grid">
      {projects.map((p) => {
        const detailHref = projectDetailHref(p);
        const status = statusLabel(p.data.status);
        const deployment = deployLabel(p.data.deployType || 'planned');
        const stack = displayStack(p);
        const topicTags = displayTopicTags(p);
        const actions = projectActions(p);

        return (
          <article class="card work-card">
            <div class="card__title">
              <a href={detailHref}>{p.data.title}</a>
            </div>
            <p class="card__desc">{p.data.description}</p>

            <div class="project-taxonomy">
              <div class="project-taxonomy__group">
                <span class="project-taxonomy__label">状态</span>
                <div class="project-taxonomy__chips">
                  {status && <span class="project-taxonomy__item">{status}</span>}
                  {deployment && <span class="project-taxonomy__item">{deployment}</span>}
                </div>
              </div>

              {stack.length > 0 && (
                <div class="project-taxonomy__group">
                  <span class="project-taxonomy__label">技术</span>
                  <div class="project-taxonomy__chips">
                    {stack.slice(0, 4).map((item: string) => (
                      <span class="project-taxonomy__item">{item}</span>
                    ))}
                  </div>
                </div>
              )}

              {topicTags.length > 0 && (
                <div class="project-taxonomy__group">
                  <span class="project-taxonomy__label">主题</span>
                  <div class="project-taxonomy__chips">
                    {topicTags.slice(0, 4).map((item: string) => (
                      <span class="project-taxonomy__item">{item}</span>
                    ))}
                  </div>
                </div>
              )}
            </div>

            <div class="project-actions" aria-label={`${p.data.title} links`}>
              {actions.map((action) => (
                <a
                  class:list={['badge', 'badge--link', { 'badge--accent': action.tone === 'accent' }]}
                  href={action.href}
                  target={action.external ? '_blank' : undefined}
                  rel={action.external ? 'noopener' : undefined}
                >
                  {action.label}
                </a>
              ))}
            </div>
          </article>
        );
      })}
    </div>

    {projects.length === 0 && (
      <p class="muted" style="text-align:center;padding:var(--space-8) 0;">
        暂无项目。在 PocketBase 后台新增项目后，这里会自动展示。
      </p>
    )}
  </main>
</BaseLayout>
