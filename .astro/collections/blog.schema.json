{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "draft": {
      "type": "boolean"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "series": {
      "type": "string"
    },
    "featured": {
      "type": "boolean"
    },
    "hero": {
      "type": "string"
    },
    "canonical": {
      "type": "string",
      "format": "uri"
    },
    "readingTime": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "summary": {
      "type": "string"
    },
    "cover": {
      "type": "string"
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "name",
          "url"
        ]
      }
    },
    "source": {
      "type": "string",
      "enum": [
        "obsidian",
        "site"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "published",
        "syndicated"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "pubDate"
  ]
}