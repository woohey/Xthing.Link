# ===== v2: PocketBase 配置 =====
# PocketBase 地址 (本地开发用 localhost, 服务器用 127.0.0.1)
POCKETBASE_URL=http://127.0.0.1:8090

# PocketBase 管理员账号 (用于 ./scripts/migrate-to-pb.mjs 和 publish-from-obsidian.mjs)
PB_ADMIN_EMAIL=admin@xthing.link
PB_ADMIN_PASS=your_password_here

# Webhook receiver 配置
WEBHOOK_PORT=4322
WEBHOOK_SECRET=

# ===== v1: PetNecklace demo 配置 =====
# mock JSON under /public/mock/pet-necklace/v1/ (default)
# PUBLIC_PET_API_MODE=mock
# When the PetNecklace backend is ready:
# PUBLIC_PET_API_MODE=live
# PUBLIC_PET_API_BASE=https://pet-api.xthing.link
